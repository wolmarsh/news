    <item>
      <title></title>
      <link>https://whimsical-macaron-cef883.netlify.app/posts/test/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://whimsical-macaron-cef883.netlify.app/posts/test/</guid>
      <description>&lt;!DOCTYPE html&gt;
&lt;html&gt;
&lt;head&gt;
&lt;title&gt;Autonomous SOC Range System&lt;/title&gt;

&lt;style&gt;
body {
    margin: 0;
    font-family: Arial;
    background: #05070c;
    color: #d0d7de;
}

#topbar {
    display: flex;
    gap: 10px;
    padding: 10px;
    background: #111a2b;
}

button {
    padding: 8px 10px;
    border: none;
    border-radius: 6px;
    background: #2563eb;
    color: white;
    cursor: pointer;
}

.grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    height: calc(100vh - 50px);
}

.panel {
    padding: 10px;
    overflow: auto;
    border-right: 1px solid #1f2937;
}

.card {
    background: #121a26;
    padding: 8px;
    margin: 6px 0;
    border-radius: 6px;
    cursor: pointer;
}

.low { border-left: 4px solid #22c55e; }
.med { border-left: 4px solid #f59e0b; }
.high { border-left: 4px solid #ef4444; }
.crit { border-left: 4px solid #b91c1c; }
.mitre { border-left: 4px solid #a78bfa; }

.small {
    font-size: 12px;
    opacity: 0.8;
}
&lt;/style&gt;
&lt;/head&gt;

&lt;body&gt;

&lt;div id=&#34;topbar&#34;&gt;
    &lt;button onclick=&#34;soc.start()&#34;&gt;▶ Start Campaign&lt;/button&gt;
    &lt;button onclick=&#34;soc.pause()&#34;&gt;⏸ Pause&lt;/button&gt;
    &lt;button onclick=&#34;soc.replay()&#34;&gt;⏪ Replay&lt;/button&gt;
    &lt;button onclick=&#34;soc.reset()&#34;&gt;Reset&lt;/button&gt;
&lt;/div&gt;

&lt;div class=&#34;grid&#34;&gt;

    &lt;div class=&#34;panel&#34;&gt;
        &lt;h3&gt;🎯 APT Campaign Stream&lt;/h3&gt;
        &lt;div id=&#34;stream&#34;&gt;&lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&#34;panel&#34;&gt;
        &lt;h3&gt;🕸 MITRE ATT&amp;CK Map (Defensive View)&lt;/h3&gt;
        &lt;div id=&#34;mitre&#34;&gt;&lt;/div&gt;

        &lt;h3&gt;👥 SOC Team View&lt;/h3&gt;
        &lt;div id=&#34;team&#34;&gt;&lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&#34;panel&#34;&gt;
        &lt;h3&gt;🤖 AI SOC Co-Pilot&lt;/h3&gt;
        &lt;div id=&#34;ai&#34; class=&#34;card&#34;&gt;&lt;/div&gt;

        &lt;h3&gt;📼 War Room Replay&lt;/h3&gt;
        &lt;div id=&#34;replay&#34;&gt;&lt;/div&gt;
    &lt;/div&gt;

&lt;/div&gt;

&lt;script&gt;
/* =========================
   APT CAMPAIGN ENGINE (DEFENSIVE MODEL)
========================= */
class APTCampaign {

    static stages = [
        &#34;recon&#34;,
        &#34;initial_access&#34;,
        &#34;execution&#34;,
        &#34;persistence&#34;,
        &#34;lateral_movement&#34;,
        &#34;exfiltration&#34;
    ];

    static generate() {

        const stage = this.stages[Math.floor(Math.random()*this.stages.length)];

        const mitreMap = {
            recon: &#34;T1595&#34;,
            initial_access: &#34;T1566&#34;,
            execution: &#34;T1059&#34;,
            persistence: &#34;T1547&#34;,
            lateral_movement: &#34;T1021&#34;,
            exfiltration: &#34;T1041&#34;
        };

        return {
            id: Math.random().toString(36).slice(2,8),
            stage,
            mitre: mitreMap[stage],
            host: [&#34;web&#34;,&#34;db&#34;,&#34;auth&#34;][Math.floor(Math.random()*3)],
            severity: Math.random(),
            ts: Date.now()
        };
    }
}

/* =========================
   AI SOC CO-PILOT
========================= */
class AISOC {

    static explain(event) {

        return `
            🧠 SOC Analysis

            Stage: ${event.stage}
            MITRE: ${event.mitre}
            Host: ${event.host}

            Interpretation:
            ${
                event.stage === &#34;recon&#34;
                ? &#34;Early reconnaissance detected. Likely probing environment.&#34;
                : event.stage === &#34;lateral_movement&#34;
                ? &#34;Movement between systems detected. Possible compromise spread.&#34;
                : &#34;Part of multi-stage intrusion chain.&#34;
            }

            Recommendation:
            → Correlate with related host activity
            → Trace previous stage in chain
            → Assess blast radius
        `;
    }
}

/* =========================
   SOC RANGE SYSTEM
========================= */
class SOCRange {

    constructor() {
        this.events = [];
        this.running = false;
        this.replayIndex = 0;

        this.team = [
            { name: &#34;Tier1-Analyst&#34;, role: &#34;triage&#34; },
            { name: &#34;Tier2-Analyst&#34;, role: &#34;investigation&#34; },
            { name: &#34;Incident-Lead&#34;, role: &#34;coordination&#34; }
        ];
    }

    start() {
        if (this.running) return;
        this.running = true;
        this.loop();
    }

    pause() {
        this.running = false;
    }

    reset() {
        this.events = [];
        this.replayIndex = 0;
        this.render();
    }

    loop() {
        if (!this.running) return;

        const event = APTCampaign.generate();
        this.events.unshift(event);

        this.render();
        this.updateAI(event);

        setTimeout(()=&gt;this.loop(), 900);
    }

    /* =========================
       REPLAY ENGINE
    ========================= */
    replay() {
        this.replayIndex = this.events.length - 1;

        const interval = setInterval(() =&gt; {

            if (this.replayIndex &lt; 0) {
                clearInterval(interval);
                return;
            }

            this.updateAI(this.events[this.replayIndex]);
            this.replayIndex--;

        }, 700);
    }

    /* =========================
       AI CO-PILOT
    ========================= */
    updateAI(event) {
        if (!event) return;

        document.getElementById(&#34;ai&#34;).innerHTML =
            AISOC.explain(event);
    }

    /* =========================
       MITRE MAPPING VIEW
    ========================= */
    renderMitre() {

        const map = {};

        for (const e of this.events) {
            map[e.mitre] = (map[e.mitre] || 0) + 1;
        }

        return Object.entries(map).map(([k,v]) =&gt; `
            &lt;div class=&#34;card mitre&#34;&gt;
                ${k}&lt;br&gt;
                Occurrences: ${v}
            &lt;/div&gt;
        `).join(&#34;&#34;);
    }

    /* =========================
       UI
    ========================= */
    render() {

        document.getElementById(&#34;stream&#34;).innerHTML =
            this.events.slice(0,10).map(e =&gt; `
                &lt;div class=&#34;card ${this.sev(e.severity)}&#34;&gt;
                    &lt;b&gt;${e.stage}&lt;/b&gt;&lt;br&gt;
                    Host: ${e.host}&lt;br&gt;
                    MITRE: ${e.mitre}
                &lt;/div&gt;
            `).join(&#34;&#34;);

        document.getElementById(&#34;mitre&#34;).innerHTML =
            this.renderMitre();

        document.getElementById(&#34;team&#34;).innerHTML =
            this.team.map(t =&gt; `
                &lt;div class=&#34;card&#34;&gt;
                    ${t.name}&lt;br&gt;
                    Role: ${t.role}
                &lt;/div&gt;
            `).join(&#34;&#34;);

        document.getElementById(&#34;replay&#34;).innerHTML =
            this.events.slice(0,6).map(e =&gt; `
                &lt;div class=&#34;card&#34;&gt;
                    ${e.stage} → ${e.mitre}
                &lt;/div&gt;
            `).join(&#34;&#34;);
    }

    sev(s) {
        if (s &gt; 0.7) return &#34;crit&#34;;
        if (s &gt; 0.5) return &#34;high&#34;;
        if (s &gt; 0.3) return &#34;med&#34;;
        return &#34;low&#34;;
    }
}

/* =========================
   BOOT
========================= */
const soc = new SOCRange();
soc.render();
&lt;/script&gt;

&lt;/body&gt;
&lt;/html&gt;</description>
